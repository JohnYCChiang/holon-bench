{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Holon Benchmark Case Result",
  "type": "object",
  "$comment": "repair_tax_rate is a derived metric (repaired_pass / final_pass) and is NOT stored in this schema. Compute it from repaired_pass and final_pass at analysis time. See HGP.md §Repair Tax.",
  "required": ["case_id", "track", "task_type", "model", "protocol", "first_pass", "final_pass", "hard_gates", "commands", "changed_files", "failure_tags"],
  "properties": {
    "case_id": { "type": "string" },
    "track": { "type": "string" },
    "task_type": { "type": "string" },
    "model": { "type": "string" },
    "protocol": { "enum": ["patch", "artifact"] },
    "driver": { "enum": ["direct", "holon-cli", "claw-cli"] },
    "generation_path": { "enum": ["direct", "holon_auto", "holon_workflow", "holon_print", "claw_cli", null] },
    "fallback_used": { "type": ["boolean", "null"] },
    "workflow_attempted": { "type": ["boolean", "null"] },
    "workflow_type": { "enum": ["none", "artifact", "graph_recall", null] },
    "governance_level": { "enum": ["blackbox_artifact", "graybox_workspace", "whitebox_native", null] },
    "prompt_stack": { "type": ["object", "null"] },
    "attempt_count": { "type": "integer", "minimum": 1 },
    "repair_used": { "type": "boolean" },
    "first_pass": {
      "type": "boolean",
      "description": "True if the first attempt passed all hard gates without repair. Maps to HGP first_attempt_verdict / first_pass. See BENCHMARK_ALIGNMENT.md."
    },
    "final_pass": {
      "type": "boolean",
      "description": "True if the final attempt (after any repairs) passed all hard gates. Maps to HGP final_verdict / final_pass. Denominator of repair_tax_rate. See BENCHMARK_ALIGNMENT.md."
    },
    "repaired_pass": {
      "type": "boolean",
      "description": "True if the first attempt failed but a later repair attempt passed. Numerator of repair_tax_rate (repaired_pass / final_pass). See HGP.md §Repair Tax."
    },
    "repair_attempts_used": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of repair attempts consumed before final verdict. Maps to HGP repair_trace.attempts. See HGP.md §Attempt."
    },
    "max_repair_attempts": { "type": "integer", "minimum": 0 },
    "max_repair_exhausted": { "type": "boolean" },
    "hard_gates": {
      "type": "object",
      "required": ["patch_applies", "compiles", "tests_pass", "schema_valid", "scope_pass", "safety_pass", "semantic_pass", "hidden_pass", "mutation_pass"],
      "properties": {
        "patch_applies": { "type": "boolean" },
        "compiles": { "type": "boolean" },
        "tests_pass": { "type": "boolean" },
        "schema_valid": { "type": "boolean" },
        "scope_pass": { "type": "boolean" },
        "safety_pass": { "type": "boolean" },
        "semantic_pass": { "type": "boolean" },
        "hidden_pass": { "type": "boolean" },
        "mutation_pass": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "commands": { "type": "array" },
    "changed_files": { "type": "array", "items": { "type": "string" } },
    "failure_tags": { "type": "array", "items": { "type": "string" } },
    "first_failure_tags": { "type": "array", "items": { "type": "string" } },
    "final_failure_tags": { "type": "array", "items": { "type": "string" } },
    "duration_seconds": { "type": "number" }
  }
}
