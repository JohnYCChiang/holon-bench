{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Holon Benchmark Case Score",
  "type": "object",
  "required": ["case_id", "track", "task_type", "model", "protocol", "hard_pass", "soft_score", "role_signals"],
  "properties": {
    "case_id": { "type": "string" },
    "track": { "type": "string" },
    "task_type": { "type": "string" },
    "model": { "type": "string" },
    "protocol": { "enum": ["patch", "artifact"] },
    "driver": { "enum": ["direct", "holon-cli", "claw-cli"] },
    "generation_path": { "enum": ["direct", "holon_auto", "holon_workflow", "holon_print", "claw_cli", null] },
    "governance_level": { "enum": ["blackbox_artifact", "graybox_workspace", "whitebox_native", null] },
    "fallback_used": { "type": ["boolean", "null"] },
    "workflow_attempted": { "type": ["boolean", "null"] },
    "workflow_type": { "enum": ["none", "artifact", "graph_recall", null] },
    "prompt_stack": { "type": ["object", "null"] },
    "tao_truth_chain": { "$ref": "#/$defs/tao_truth_chain" },
    "attempt_count": { "type": "integer", "minimum": 1 },
    "repair_used": { "type": "boolean" },
    "first_pass": { "type": "boolean" },
    "final_pass": { "type": "boolean" },
    "repaired_pass": { "type": "boolean" },
    "repair_attempts_used": { "type": "integer", "minimum": 0 },
    "max_repair_attempts": { "type": "integer", "minimum": 0 },
    "max_repair_exhausted": { "type": "boolean" },
    "hard_pass": { "type": "boolean" },
    "soft_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "role_signals": {
      "type": "object",
      "required": ["contract_worker", "patch_worker", "reviewer", "planner", "tool_maker", "porting_worker", "game_system_worker", "cross_platform_app_worker"],
      "properties": {
        "contract_worker": { "type": "number", "minimum": 0, "maximum": 1 },
        "patch_worker": { "type": "number", "minimum": 0, "maximum": 1 },
        "reviewer": { "type": "number", "minimum": 0, "maximum": 1 },
        "planner": { "type": "number", "minimum": 0, "maximum": 1 },
        "tool_maker": { "type": "number", "minimum": 0, "maximum": 1 },
        "porting_worker": { "type": "number", "minimum": 0, "maximum": 1 },
        "game_system_worker": { "type": "number", "minimum": 0, "maximum": 1 },
        "cross_platform_app_worker": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "failure_tags": { "type": "array", "items": { "type": "string" } },
    "first_failure_tags": { "type": "array", "items": { "type": "string" } },
    "final_failure_tags": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "tao_truth_chain": {
      "type": ["object", "null"],
      "description": "Optional Tao truth-chain references preserved from benchmark result metadata. Omit or null when unavailable.",
      "required": ["subject_id"],
      "properties": {
        "subject_id": { "type": "string" },
        "artifact_ids": { "type": "array", "items": { "type": "string" } },
        "fact_kind": { "type": "string" },
        "fact_id": { "type": "string" },
        "verifier_input_ids": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
