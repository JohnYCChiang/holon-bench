__pycache__/
*.py[cod]
.holon/
**/.holon/

# Benchmark run artifacts are regenerated and noisy. Keep only the stable
# summary reports tracked.
reports/*
!reports/
!reports/model_matrix.md
!reports/per_track.json
!reports/routing_recommendation.json
!reports/baseline_summary.md

# Stray tao stores from local authoring (absolute store lives in /tmp or ~/tao-killtest-private)
.tao/
**/.tao/

# Answer key — kept PRIVATE so the public benchmark cannot be gamed by reading
# the repo. These live on disk (and in the private companion repo
# holon-bench-private) but are NOT published. The harness/oracle reads them
# locally; a public clone validates structure only.
/solutions/
fixtures/**/hidden/
